## ========================================
## C++ Build Artifacts (Compiled Languages)
## ========================================
# Object files
*.o
*.ko
*.obj
*.elf

# Precompiled headers
*.gch
*.pch
*.pchi

# Executables
*.exe
*.out
*.app
*.dll
*.so
*.dylib
*.exe.manifest

# Static and dynamic libraries
*.lib
*.a
*.la
*.lo
*.dll.a
*.dylib

# Debug files
*.pdb
*.idb
*.pdb
*.ipdb
*.iobj
*.ilk
*.dSYM/
*.dSYM.zip

# Build directories (common names)
[Bb]uild/
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
ARM64/
*.tlog/
*.lastbuildstate

## ========================================
## Emscripten / WebAssembly
## ========================================
# Compiled WASM outputs (keep only if needed; many devs ignore these)
*.wasm
*.wasm.map
*.wast
*.wasm.decompile
*.js.LEGACY
*.js.mem
*.worker.js

# Generated JS glue code (often excluded if source is tracked)
*-wasm.js
*-wasm.wasm
emscripten-*.txt

## ========================================
## Python Build Scripts
## ========================================
# Byte-compiled files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
env/
venv/
.venv/
env.bak/
venv.bak/
pythonenv*

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

## ========================================
## TypeScript / Node.js
## ========================================
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript compilation
*.tsbuildinfo
dist/
out/
build/web/*.js    # Compiled JS from TypeScript
web/*.js
!web/*.config.js  # Exception for config files

# Package manager locks (keep these if you want deterministic installs)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment files
.env
.env.local
.env.*.local

## ========================================
## Visual Studio / IDE Files
## ========================================
# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
[Bb]in/
[Oo]bj/
[Bb]uild/

# Visual Studio 2015+ cache/options directory
.vs/

# Visual Studio Code
.vscode/
!.vscode/*.json   # Keep settings if you want them versioned
!.vscode/tasks.json
!.vscode/launch.json

# JetBrains IDEs
.idea/
*.iml
*.iws

## ========================================
## Windows OS Files
## ========================================
# Windows thumbnail cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Folder config
[Dd]esktop.ini

# Recycle Bin
$RECYCLE.BIN/

# Windows shortcuts
*.lnk

## ========================================
## macOS Files
## ========================================
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Thumbnails
._*

# Files that might appear on external disk
.Spotlight-V100
.Trashes

## ========================================
## Linux Files
## ========================================
*~
.swp
.swo
*.lock

## ========================================
## Project-Specific Exclusions
## ========================================
# Build outputs
build/wasm/
build/web/
!build/wasm/.gitkeep   # Keep folder structure if you add .gitkeep files
!build/web/.gitkeep

# Generated documentation
docs/generated/

# Temporary files
temp/
tmp/
*.tmp
*.temp

# Log files
*.log
logs/

# Backup files
*.bak
*.old
*.orig

# Coverage reports
coverage/
*.lcov

## ========================================
## Important! Keep your source code
## ========================================
# DO NOT ignore these:
!**/*.cpp
!**/*.h
!**/*.hpp
!web/*.html
!web/*.css
!web/*.ts
!scripts/*.py
!build.py
!LICENSE
!README.md
!CONTRIBUTING.md
!docs/*.md