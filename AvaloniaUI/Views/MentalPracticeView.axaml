<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaUI.Views.MentalPracticeView"
             x:DataType="vm:MentalPracticeViewModel">

  <Panel Background="{DynamicResource ContentBackgroundBrush}">

    <!-- Setup Screen -->
    <Border IsVisible="{Binding IsInSetup}"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="24" MaxWidth="480" HorizontalAlignment="Center">
        <!-- Icon -->
        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="16"
                Width="72" Height="72" HorizontalAlignment="Center">
          <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="{DynamicResource PrimaryBrush}" />
        </Border>

        <!-- Title & Description -->
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <TextBlock Text="Mental Practice" FontSize="28" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Test your recall speed! Random questions, timed."
                     FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" TextWrapping="Wrap"
                     TextAlignment="Center" MaxWidth="400" />
        </StackPanel>

        <!-- Scope Selector -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="8">
            <TextBlock Text="Scope" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <ComboBox ItemsSource="{Binding ScopeOptions}" SelectedItem="{Binding SelectedScope}"
                      HorizontalAlignment="Stretch" Padding="8,6" />
          </StackPanel>
        </Border>

        <!-- Start Button -->
        <Button Command="{Binding StartCommand}"
                HorizontalAlignment="Center"
                Padding="32,14" CornerRadius="8"
                Background="{DynamicResource PrimaryBrush}"
                Foreground="{DynamicResource TextOnPrimaryBrush}"
                MinWidth="180">
          <TextBlock Text="Start Practice" FontSize="16" FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
        </Button>
      </StackPanel>
    </Border>

    <!-- Countdown Overlay -->
    <Border IsVisible="{Binding IsCountdown}"
            Background="{DynamicResource ContentBackgroundBrush}"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <TextBlock Text="{Binding CountdownValue}"
                 FontSize="120" FontWeight="Bold"
                 Foreground="{DynamicResource PrimaryBrush}"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Border>

    <!-- Practice Area -->
    <DockPanel IsVisible="{Binding IsInPractice}">

      <!-- Top Bar -->
      <Border DockPanel.Dock="Top" Background="{DynamicResource CardBackgroundBrush}"
              BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
              Padding="16,8">
        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
          <!-- Progress -->
          <TextBlock Grid.Column="0" Text="{Binding ProgressText}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     VerticalAlignment="Center" />

          <!-- Session Timer -->
          <TextBlock Grid.Column="1" Text="{Binding SessionTimerText}"
                     FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center" />

          <!-- Controls -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding PauseCommand}" Padding="8,4" CornerRadius="6"
                    Background="Transparent" ToolTip.Tip="Pause">
              <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Button>
            <Button Command="{Binding GiveUpCommand}" Padding="8,4" CornerRadius="6"
                    Background="Transparent" ToolTip.Tip="Give Up">
              <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </Button>
            <Button Command="{Binding EndSessionCommand}" Padding="8,4" CornerRadius="6"
                    Background="Transparent" ToolTip.Tip="End Session">
              <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         Foreground="{DynamicResource ErrorBrush}" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Question Content -->
      <ScrollViewer>
        <StackPanel Spacing="24" Margin="48,32">

          <!-- Question Timer -->
          <TextBlock Text="{Binding QuestionTimerText}" FontSize="36" FontWeight="Bold"
                     Foreground="{DynamicResource TimerNormalBrush}"
                     HorizontalAlignment="Center" />

          <!-- Streak Display -->
          <StackPanel IsVisible="{Binding HasStreak}" Orientation="Horizontal"
                      Spacing="4" HorizontalAlignment="Center">
            <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       Foreground="{DynamicResource WarningBrush}"
                       IsVisible="{Binding HasFireStreak}"
                       VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentStreak}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource WarningBrush}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Question Card -->
          <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                  Padding="32,24" BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1" MaxWidth="700" HorizontalAlignment="Center">
            <TextBlock Text="{Binding QuestionText}" FontSize="18"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap" />
          </Border>

          <!-- MC Answer Cards -->
          <ItemsControl IsVisible="{Binding IsMultipleChoice}" MaxWidth="700"
                        HorizontalAlignment="Center"
                        ItemsSource="{Binding Choices}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="8" Padding="16,12" Margin="0,4"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Cursor="Hand">
                  <Grid ColumnDefinitions="32,*">
                    <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                            Width="28" Height="28" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                      <TextBlock FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               TextWrapping="Wrap" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- SA Answer Input -->
          <StackPanel IsVisible="{Binding !IsMultipleChoice}" Spacing="8"
                      MaxWidth="700" HorizontalAlignment="Center">
            <TextBox Text="{Binding CurrentAnswer}" Watermark="Type your answer..."
                     FontSize="16" Padding="12,10" CornerRadius="8" />
            <TextBlock Text="Press Enter to submit" FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </DockPanel>

    <!-- Paused Overlay -->
    <Border IsVisible="{Binding IsPaused}"
            Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="Paused" FontSize="36" FontWeight="Bold"
                   Foreground="{DynamicResource TextOnPrimaryBrush}"
                   HorizontalAlignment="Center" />
        <Button Command="{Binding ResumeCommand}"
                Padding="24,12" CornerRadius="8"
                Background="{DynamicResource PrimaryBrush}"
                Foreground="{DynamicResource TextOnPrimaryBrush}"
                HorizontalAlignment="Center">
          <TextBlock Text="Resume" FontSize="16" FontWeight="SemiBold" />
        </Button>
      </StackPanel>
    </Border>

    <!-- Feedback Overlay -->
    <Border IsVisible="{Binding IsInFeedback}"
            Background="{DynamicResource ContentBackgroundBrush}"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Correct -->
        <Border IsVisible="{Binding LastAnswerCorrect}"
                Background="{DynamicResource CorrectBackgroundBrush}"
                BorderBrush="{DynamicResource CorrectBorderBrush}" BorderThickness="2"
                CornerRadius="12" Padding="32,24" MinWidth="300">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="{DynamicResource CorrectTextBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Correct!" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource CorrectTextBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Incorrect -->
        <Border IsVisible="{Binding !LastAnswerCorrect}"
                Background="{DynamicResource IncorrectBackgroundBrush}"
                BorderBrush="{DynamicResource IncorrectBorderBrush}" BorderThickness="2"
                CornerRadius="12" Padding="32,24" MinWidth="300">
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="{DynamicResource IncorrectTextBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="{Binding FeedbackMessage}" FontSize="18"
                       Foreground="{DynamicResource IncorrectTextBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap"
                       TextAlignment="Center" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <!-- Session Over -->
    <Border IsVisible="{Binding IsSessionOver}"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="24" MaxWidth="480" HorizontalAlignment="Center">
        <TextBlock Text="Session Complete!" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" />

        <!-- Stats Grid -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,8">

            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" Margin="0,8">
              <TextBlock Text="Questions" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding QuestionsAnswered}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4" Margin="0,8">
              <TextBlock Text="Correct" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding CorrectCount}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource SuccessBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,8">
              <TextBlock Text="Accuracy" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding AccuracyText}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,8">
              <TextBlock Text="Speed Rating" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding SpeedRating}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource PrimaryBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4" Margin="0,8">
              <TextBlock Text="Best Streak" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding BestStreak}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource WarningBrush}" />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4" Margin="0,8">
              <TextBlock Text="Total Time" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
              <TextBlock Text="{Binding SessionTimerText}" FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

          </Grid>
        </Border>

        <Button Command="{Binding StartCommand}"
                HorizontalAlignment="Center"
                Padding="24,12" CornerRadius="8"
                Background="{DynamicResource PrimaryBrush}"
                Foreground="{DynamicResource TextOnPrimaryBrush}">
          <TextBlock Text="Practice Again" FontSize="14" FontWeight="SemiBold" />
        </Button>
      </StackPanel>
    </Border>

  </Panel>
</UserControl>
