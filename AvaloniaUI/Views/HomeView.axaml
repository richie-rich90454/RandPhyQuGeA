<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaUI.Views.HomeView"
             x:DataType="vm:HomeViewModel">

  <ScrollViewer Background="{DynamicResource ContentBackgroundBrush}">
    <StackPanel Spacing="24" Margin="48,40">

      <!-- Welcome Section -->
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding WelcomeTitle}" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="{Binding WelcomeDescription}" FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                   MaxWidth="600" />
      </StackPanel>

      <!-- Daily Physics Quote -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24,20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              MaxWidth="700" BoxShadow="0 2 4 0 rgba(0,0,0,0.06)">
        <StackPanel Spacing="8">
          <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                     Foreground="{DynamicResource PrimaryBrush}" Opacity="0.6" />
          <TextBlock Text="{Binding DailyQuote}" FontSize="15" FontStyle="Italic"
                     Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                     MaxWidth="650" />
          <TextBlock Text="{Binding DailyQuoteAuthor}" FontSize="12"
                     Foreground="{DynamicResource TextTertiaryBrush}" />
        </StackPanel>
      </Border>

      <!-- Quick Start Cards -->
      <TextBlock Text="Quick Start" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" />

      <Grid ColumnDefinitions="*,*" MaxWidth="700">
        <!-- Mental Practice Card -->
        <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12" Padding="24" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" BoxShadow="0 2 4 0 rgba(0,0,0,0.08)" Margin="0,0,8,0">
          <StackPanel Spacing="12">
            <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                    Width="48" Height="48" HorizontalAlignment="Left">
              <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}" />
            </Border>
            <TextBlock Text="Mental Practice" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Practice physics problems mentally with timed challenges and progressive difficulty."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <Button HorizontalAlignment="Left" Padding="16,8" CornerRadius="6"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource TextOnPrimaryBrush}"
                    Click="StartMentalPractice_Click">
              <TextBlock Text="Start" FontSize="13" FontWeight="SemiBold" />
            </Button>
          </StackPanel>
        </Border>

        <!-- Focused Practice Card -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="12" Padding="24" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" BoxShadow="0 2 4 0 rgba(0,0,0,0.08)" Margin="8,0,0,0">
          <StackPanel Spacing="12">
            <Border Background="{DynamicResource InfoLightBrush}" CornerRadius="8"
                    Width="48" Height="48" HorizontalAlignment="Left">
              <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource InfoBrush}" />
            </Border>
            <TextBlock Text="Focused Practice" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Focus on specific topics and skills with targeted question generation and detailed solutions."
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <Button HorizontalAlignment="Left" Padding="16,8" CornerRadius="6"
                    Background="{DynamicResource InfoBrush}"
                    Foreground="{DynamicResource TextOnAccentBrush}"
                    Click="StartFocusedPractice_Click">
              <TextBlock Text="Start" FontSize="13" FontWeight="SemiBold" />
            </Button>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Recent Activity Section -->
      <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />

      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1" MaxWidth="700">
        <StackPanel Spacing="8">
          <!-- Recent sessions list -->
          <ItemsControl ItemsSource="{Binding RecentSessions}" IsVisible="{Binding HasRecentSessions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:HomeRecentSessionItem">
                <Grid ColumnDefinitions="*,Auto,Auto" MinHeight="32" Margin="0,4">
                  <TextBlock Text="{Binding DateText}" FontSize="13"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding ScoreText}" FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="16,0" />
                  <TextBlock Grid.Column="2" Text="{Binding AccuracyText}" FontSize="13"
                             Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <!-- Empty state -->
          <StackPanel IsVisible="{Binding !HasRecentSessions}" Spacing="12">
            <TextBlock Text="No recent activity yet." FontSize="13"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,16" />
            <TextBlock Text="Start a practice session to see your history here." FontSize="12"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
