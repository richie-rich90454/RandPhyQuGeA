<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="AvaloniaUI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

  <ScrollViewer Background="{DynamicResource ContentBackgroundBrush}">
    <Grid>
    <StackPanel Margin="48,40" MaxWidth="640" HorizontalAlignment="Left" Spacing="32">

      <!-- Page Title -->
      <StackPanel Spacing="8">
        <TextBlock Text="Settings" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        <TextBlock Text="Customize your experience"
                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" />
      </StackPanel>

      <!-- ═══ Theme Section ═══ -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <!-- Section Header -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                    Width="36" Height="36" VerticalAlignment="Center">
              <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource PrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Theme" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Choose the application appearance" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </StackPanel>

          <!-- Theme Options -->
          <StackPanel Spacing="8">
            <!-- Light -->
            <Border Background="{DynamicResource CardHoverBrush}" CornerRadius="8"
                    Padding="16,12" Cursor="Hand"
                    PointerPressed="OnLightThemeClick"
                    AutomationProperties.Name="Light theme">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Width="32" Height="32" CornerRadius="6"
                        Background="#FFFFFF" BorderBrush="#DADCE0" BorderThickness="1"
                        VerticalAlignment="Center">
                  <TextBlock Text="&#xE706;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                             Foreground="#F57C00" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="Light" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="Bright, clean interface" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>
                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                        BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsLightSelected}">
                  <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8"
                          Margin="3" />
                </Border>
              </Grid>
            </Border>

            <!-- Dark -->
            <Border Background="{DynamicResource CardHoverBrush}" CornerRadius="8"
                    Padding="16,12" Cursor="Hand"
                    PointerPressed="OnDarkThemeClick"
                    AutomationProperties.Name="Dark theme">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Width="32" Height="32" CornerRadius="6"
                        Background="#1A1A2E" BorderBrush="#2D3A54" BorderThickness="1"
                        VerticalAlignment="Center">
                  <TextBlock Text="&#xE708;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                             Foreground="#9AA0A6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="Dark" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="Easy on the eyes, reduced glare" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>
                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                        BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsDarkSelected}">
                  <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8"
                          Margin="3" />
                </Border>
              </Grid>
            </Border>

            <!-- System -->
            <Border Background="{DynamicResource CardHoverBrush}" CornerRadius="8"
                    Padding="16,12" Cursor="Hand"
                    PointerPressed="OnSystemThemeClick"
                    AutomationProperties.Name="System theme">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Width="32" Height="32" CornerRadius="6"
                        Background="{DynamicResource PrimarySubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        VerticalAlignment="Center">
                  <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                             Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="System" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                  <TextBlock Text="Follow your operating system setting" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>
                <Border Grid.Column="2" Width="20" Height="20" CornerRadius="10"
                        BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsSystemSelected}">
                  <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="8"
                          Margin="3" />
                </Border>
              </Grid>
            </Border>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ═══ Practice Defaults Section ═══ -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <!-- Section Header -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                    Width="36" Height="36" VerticalAlignment="Center">
              <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource PrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Practice Defaults" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Default settings for new practice sessions" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </StackPanel>

          <!-- Default Question Count -->
          <StackPanel Spacing="8">
            <TextBlock Text="Default Question Count" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="BtnCount5" Content="5" Padding="16,8" CornerRadius="6"
                      Background="{DynamicResource Neutral10Brush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="OnQuestionCount5Click"
                      AutomationProperties.Name="5 questions" />
              <Button x:Name="BtnCount10" Content="10" Padding="16,8" CornerRadius="6"
                      Background="{DynamicResource PrimarySubtleBrush}"
                      Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                      Click="OnQuestionCount10Click"
                      AutomationProperties.Name="10 questions" />
              <Button x:Name="BtnCount15" Content="15" Padding="16,8" CornerRadius="6"
                      Background="{DynamicResource Neutral10Brush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="OnQuestionCount15Click"
                      AutomationProperties.Name="15 questions" />
              <Button x:Name="BtnCount20" Content="20" Padding="16,8" CornerRadius="6"
                      Background="{DynamicResource Neutral10Brush}"
                      Foreground="{DynamicResource TextPrimaryBrush}"
                      Click="OnQuestionCount20Click"
                      AutomationProperties.Name="20 questions" />
            </StackPanel>
          </StackPanel>

          <!-- Default Difficulty Range -->
          <StackPanel Spacing="8">
            <TextBlock Text="Default Difficulty Range" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="Auto,16,*,16,Auto" VerticalAlignment="Center">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Min" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                <NumericUpDown Value="{Binding DefaultMinDifficulty}" Minimum="1" Maximum="10"
                               Width="80" FormatString="0"
                               AutomationProperties.Name="Minimum difficulty" />
              </StackPanel>
              <Border Grid.Column="2" Height="2" Background="{DynamicResource ProgressBarFillBrush}"
                      VerticalAlignment="Center" CornerRadius="1" />
              <StackPanel Grid.Column="4" Spacing="4">
                <TextBlock Text="Max" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                <NumericUpDown Value="{Binding DefaultMaxDifficulty}" Minimum="1" Maximum="10"
                               Width="80" FormatString="0"
                               AutomationProperties.Name="Maximum difficulty" />
              </StackPanel>
            </Grid>
          </StackPanel>

          <!-- Default Question Type -->
          <StackPanel Spacing="8">
            <TextBlock Text="Default Question Type" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="BtnTypeMC" Content="MC" Padding="20,8" CornerRadius="6"
                      Background="{DynamicResource BadgeMCBrush}"
                      Foreground="{DynamicResource TextOnPrimaryBrush}"
                      FontWeight="SemiBold" FontSize="13"
                      Click="OnTypeMCClick"
                      AutomationProperties.Name="Multiple choice" />
              <Button x:Name="BtnTypeSA" Content="SA" Padding="20,8" CornerRadius="6"
                      Background="{DynamicResource Neutral10Brush}"
                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                      Click="OnTypeSAClick"
                      AutomationProperties.Name="Short answer" />
              <Button x:Name="BtnTypeMixed" Content="Mixed" Padding="20,8" CornerRadius="6"
                      Background="{DynamicResource Neutral10Brush}"
                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                      Click="OnTypeMixedClick"
                      AutomationProperties.Name="Mixed question types" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ═══ UI Preferences Section ═══ -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <!-- Section Header -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                    Width="36" Height="36" VerticalAlignment="Center">
              <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource PrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Preferences" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Sound and display options" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </StackPanel>

          <!-- Sound Toggle -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Sound Effects" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Play sounds for correct and incorrect answers" FontSize="11"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsSoundEnabled}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Sound effects toggle" />
          </Grid>

          <Border Height="1" Background="{DynamicResource DividerBrush}" />

          <!-- Timer Visibility Toggle -->
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Show Timer" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Display the question timer during practice" FontSize="11"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsTimerVisible}"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Timer visibility toggle" />
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══ About Section ═══ -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <!-- Section Header -->
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                    Width="36" Height="36" VerticalAlignment="Center">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource PrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="About" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Application information" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </StackPanel>

          <!-- App Info -->
          <StackPanel Spacing="8" HorizontalAlignment="Center">
            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12"
                    Width="56" Height="56" HorizontalAlignment="Center">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                         Foreground="{DynamicResource TextOnPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Physics Question Generator" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Version 1.0.0" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="A cross-platform physics question generator built with .NET 8 and Avalonia UI. Generates practice questions from specification files with LaTeX support and multiple export formats."
                       FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="480"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Apache License 2.0" FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ═══ Reset Section ═══ -->
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Border Background="{DynamicResource ErrorLightBrush}" CornerRadius="8"
                    Width="36" Height="36" VerticalAlignment="Center">
              <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                         Foreground="{DynamicResource ErrorBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center">
              <TextBlock Text="Reset Settings" FontSize="16" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Restore all settings to their default values" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </StackPanel>

          <Button Command="{Binding ResetSettingsCommand}"
                  HorizontalAlignment="Left"
                  Padding="20,10" CornerRadius="8"
                  Background="{DynamicResource ErrorLightBrush}"
                  Foreground="{DynamicResource ErrorBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         VerticalAlignment="Center" />
              <TextBlock Text="Reset to Defaults" FontSize="13" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

    </StackPanel>

    <!-- ═══ Reset Confirmation Overlay ═══ -->
    <Border IsVisible="{Binding IsResetConfirmationVisible}"
            Background="#80000000"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            ZIndex="100">
      <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
              Padding="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              MinWidth="360" MaxWidth="440">
        <StackPanel Spacing="20">
          <TextBlock Text="Reset All Settings?" FontSize="20" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="This will restore all settings to their default values. This action cannot be undone."
                     FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" />
          <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Command="{Binding CancelResetCommand}"
                    Padding="16,10" CornerRadius="8"
                    Background="{DynamicResource Neutral10Brush}"
                    Foreground="{DynamicResource TextPrimaryBrush}">
              <TextBlock Text="Cancel" FontSize="13" />
            </Button>
            <Button Command="{Binding ConfirmResetCommand}"
                    Padding="16,10" CornerRadius="8"
                    Background="{DynamicResource ErrorBrush}"
                    Foreground="{DynamicResource TextOnPrimaryBrush}">
              <TextBlock Text="Reset" FontSize="13" FontWeight="SemiBold" />
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>

    </Grid>
  </ScrollViewer>
</UserControl>
