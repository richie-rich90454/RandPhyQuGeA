<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:conv="using:AvaloniaUI.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaUI.Views.FocusedPracticeView"
             x:DataType="vm:FocusedPracticeViewModel">

  <UserControl.Resources>
    <conv:LevelToVisibilityConverter x:Key="LevelToVisibilityConverter" />
  </UserControl.Resources>

  <ScrollViewer Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="48,40" MaxWidth="700" HorizontalAlignment="Left">

      <!-- Step 1: Scope Selection -->
      <StackPanel IsVisible="{Binding IsSelectingScope}" Spacing="24">

        <!-- Step Indicator -->
        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                Padding="16,10" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12"
                    Width="24" Height="24" VerticalAlignment="Center">
              <TextBlock Text="1" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource TextOnPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Select What to Practice" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Title -->
        <StackPanel Spacing="8">
          <TextBlock Text="Focused Practice" FontSize="28" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Choose the topics and skills you want to practice, then start your session."
                     FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" MaxWidth="600" />
        </StackPanel>

        <!-- Hierarchical Scope Selection Tree -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="4">
            <TextBlock Text="Topics &amp; Skills" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding ScopeItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ScopeCheckItem">
                  <StackPanel Margin="0,2">
                    <!-- Unit Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Unit}"
                              Margin="0,4">
                      <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </CheckBox>
                    <!-- Topic Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Topic}"
                              Margin="24,2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4" Padding="4,2">
                          <TextBlock Text="Topic" FontSize="10" Foreground="{DynamicResource PrimaryBrush}" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                      </StackPanel>
                    </CheckBox>
                    <!-- Skill Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Skill}"
                              Margin="48,2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource InfoLightBrush}" CornerRadius="4" Padding="4,2">
                          <TextBlock Text="Skill" FontSize="10" Foreground="{DynamicResource InfoBrush}" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                      </StackPanel>
                    </CheckBox>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Difficulty Range -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="Difficulty Range" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="Auto,16,*,16,Auto" VerticalAlignment="Center">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Min" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                <NumericUpDown Value="{Binding MinDifficulty}" Minimum="1" Maximum="10"
                               Width="80" FormatString="0" />
              </StackPanel>
              <Border Grid.Column="2" Height="2" Background="{DynamicResource ProgressBarFillBrush}"
                      VerticalAlignment="Center" CornerRadius="1" />
              <StackPanel Grid.Column="4" Spacing="4">
                <TextBlock Text="Max" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                <NumericUpDown Value="{Binding MaxDifficulty}" Minimum="1" Maximum="10"
                               Width="80" FormatString="0" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>

      <!-- Practice Session (hidden during scope selection) -->
      <StackPanel IsVisible="{Binding !IsSelectingScope}" Spacing="24">
        <TextBlock Text="Practice session will appear here" FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,48" />
      </StackPanel>

    </Grid>
  </ScrollViewer>
</UserControl>
