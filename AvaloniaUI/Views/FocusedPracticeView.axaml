<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:conv="using:AvaloniaUI.Converters"
             xmlns:ctrl="using:AvaloniaUI.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaUI.Views.FocusedPracticeView"
             x:DataType="vm:FocusedPracticeViewModel">

  <UserControl.Resources>
    <conv:LevelToVisibilityConverter x:Key="LevelToVisibilityConverter" />
    <conv:DifficultyToBrushConverter x:Key="DifficultyToBrushConverter" />
  </UserControl.Resources>

  <ScrollViewer Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="48,40" MaxWidth="700" HorizontalAlignment="Left">

      <!-- Step 1: Scope Selection -->
      <StackPanel IsVisible="{Binding IsSelectingScope}" Spacing="24">

        <!-- Step Indicator -->
        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="8"
                Padding="16,10" HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12"
                    Width="24" Height="24" VerticalAlignment="Center">
              <TextBlock Text="1" FontSize="12" FontWeight="Bold"
                         Foreground="{DynamicResource TextOnPrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Select What to Practice" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Title -->
        <StackPanel Spacing="8">
          <TextBlock Text="Focused Practice" FontSize="28" FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <TextBlock Text="Choose the topics and skills you want to practice, then start your session."
                     FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" MaxWidth="600" />
        </StackPanel>

        <!-- Hierarchical Scope Selection Tree -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="4">
            <TextBlock Text="Topics &amp; Skills" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8" />
            <ItemsControl ItemsSource="{Binding ScopeItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ScopeCheckItem">
                  <StackPanel Margin="0,2">
                    <!-- Unit Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Unit}"
                              Margin="0,4">
                      <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                 Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                    </CheckBox>
                    <!-- Topic Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Topic}"
                              Margin="24,2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4" Padding="4,2">
                          <TextBlock Text="Topic" FontSize="10" Foreground="{DynamicResource PrimaryBrush}" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                      </StackPanel>
                    </CheckBox>
                    <!-- Skill Level -->
                    <CheckBox IsChecked="{Binding IsChecked}"
                              IsVisible="{Binding Level, Converter={StaticResource LevelToVisibilityConverter}, ConverterParameter=Skill}"
                              Margin="48,2">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Background="{DynamicResource InfoLightBrush}" CornerRadius="4" Padding="4,2">
                          <TextBlock Text="Skill" FontSize="10" Foreground="{DynamicResource InfoBrush}" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                      </StackPanel>
                    </CheckBox>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Difficulty Range -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="Difficulty Range" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="Min" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                         Width="36" />
              <Slider Grid.Row="0" Grid.Column="1" Minimum="1" Maximum="10"
                      Value="{Binding MinDifficulty}" TickFrequency="1" IsSnapToTickEnabled="True"
                      Margin="8,0,0,0" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="Max" FontSize="12"
                         Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"
                         Width="36" />
              <Slider Grid.Row="1" Grid.Column="1" Minimum="1" Maximum="10"
                      Value="{Binding MaxDifficulty}" TickFrequency="1" IsSnapToTickEnabled="True"
                      Margin="8,0,0,0" />
            </Grid>
            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" HorizontalAlignment="Center">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} – {1}">
                  <Binding Path="MinDifficulty" />
                  <Binding Path="MaxDifficulty" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Border>

        <!-- Question Type Toggle -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="Question Type" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button x:Name="BtnTypeMC" Content="MC" Padding="20,8" CornerRadius="6"
                      Classes="type-selected"
                      FontSize="13"
                      Click="OnQuestionTypeMCClick" />
              <Button x:Name="BtnTypeSA" Content="SA" Padding="20,8" CornerRadius="6"
                      Classes="secondary"
                      FontSize="13"
                      Click="OnQuestionTypeSAClick" />
              <Button x:Name="BtnTypeMixed" Content="Mixed" Padding="20,8" CornerRadius="6"
                      Classes="secondary"
                      FontSize="13"
                      Click="OnQuestionTypeMixedClick" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Question Count Selector -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="12">
            <TextBlock Text="Number of Questions" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <ComboBox x:Name="QuestionCountCombo" SelectedIndex="1"
                      HorizontalAlignment="Stretch" Padding="8,6">
              <ComboBoxItem Content="5" />
              <ComboBoxItem Content="10" />
              <ComboBoxItem Content="15" />
              <ComboBoxItem Content="20" />
              <ComboBoxItem Content="All" />
            </ComboBox>
          </StackPanel>
        </Border>

        <!-- Start Practice Button with Scope Summary -->
        <StackPanel Spacing="12" HorizontalAlignment="Center">
          <TextBlock x:Name="ScopeSummaryText" Text="{Binding SelectedScopeDescription}"
                     FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                     HorizontalAlignment="Center" IsVisible="{Binding SelectedScopeDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                     TextWrapping="Wrap" TextAlignment="Center" MaxWidth="400" />
          <Button Command="{Binding StartPracticeCommand}"
                  HorizontalAlignment="Center"
                  Padding="32,14" CornerRadius="8"
                  Classes="primary"
                  MinWidth="200">
            <TextBlock Text="Start Practice" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
          </Button>
        </StackPanel>

      </StackPanel>

      <!-- Practice Session (hidden during scope selection) -->
      <StackPanel IsVisible="{Binding !IsSelectingScope}" Spacing="24">

        <!-- Progress Indicator (Commit 51) -->
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding ProgressText}" FontSize="13" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
          <ProgressBar Value="{Binding ProgressPercent}" Minimum="0" Maximum="100"
                       Height="4" CornerRadius="2"
                       Foreground="{DynamicResource ProgressBarFillBrush}"
                       Background="{DynamicResource ProgressBarBackgroundBrush}" />
        </StackPanel>

        <!-- Question Display Card (Commit 45) -->
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="32,24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
          <StackPanel Spacing="16">
            <!-- Question Number Badge & Type/Difficulty Tags -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12"
                      Padding="10,4">
                <TextBlock FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource TextOnPrimaryBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}Q{0}">
                      <Binding Path="CurrentQuestionIndex" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Border>
              <Border Background="{DynamicResource BadgeMCBrush}" CornerRadius="4" Padding="6,2"
                      x:Name="TypeBadge">
                <TextBlock Text="{Binding CurrentQuestion.QuestionType}" FontSize="10"
                           Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
              </Border>
              <Border CornerRadius="4" Padding="6,2" x:Name="DifficultyBadge">
                <Border.Background>
                  <Binding Path="CurrentQuestion.Difficulty" Converter="{StaticResource DifficultyToBrushConverter}" />
                </Border.Background>
                <TextBlock FontSize="10" Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold">
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}Diff {0}">
                      <Binding Path="CurrentQuestion.Difficulty" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </Border>
            </StackPanel>

            <!-- Question Text -->
            <Panel>
              <ctrl:LaTeXImage LaTeXSource="{Binding CurrentQuestion.Text}"
                               IsVisible="{Binding QuestionHasLaTeX}"
                               HorizontalAlignment="Left" />
              <TextBlock Text="{Binding CurrentQuestion.Text}" FontSize="18"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         TextWrapping="Wrap" LineHeight="26"
                         IsVisible="{Binding !QuestionHasLaTeX}" />
            </Panel>
          </StackPanel>
        </Border>

        <!-- MC Answer Selection -->
        <ItemsControl x:Name="McChoicesList"
                      IsVisible="{Binding IsMcQuestion}"
                      ItemsSource="{Binding CurrentQuestion.Choices}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border x:Name="ChoiceCard" Background="{DynamicResource CardBackgroundBrush}"
                      CornerRadius="8" Padding="16,12" Margin="0,4"
                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                      Cursor="Hand" PointerPressed="OnMcChoiceClick"
                      KeyDown="OnChoiceKeyDown"
                      IsTabStop="True"
                      Loaded="OnChoiceCardLoaded">
                <Grid ColumnDefinitions="36,*">
                  <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="4"
                          Width="32" Height="32" VerticalAlignment="Center"
                          HorizontalAlignment="Center">
                    <TextBlock x:Name="ChoiceLetter" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1" Text="{Binding}" FontSize="14"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             VerticalAlignment="Center" Margin="12,0,0,0"
                             TextWrapping="Wrap" />
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- MC Confirm Button (Commit 46) -->
        <Button x:Name="McConfirmBtn" Click="OnMcConfirmClick"
                HorizontalAlignment="Center"
                Padding="24,10" CornerRadius="8"
                Classes="primary"
                IsVisible="{Binding IsMcQuestion}">
          <TextBlock Text="Confirm Answer" FontSize="14" FontWeight="SemiBold" />
        </Button>

        <!-- SA Answer Input -->
        <StackPanel Spacing="8" MaxWidth="700" HorizontalAlignment="Center">
          <StackPanel.IsVisible>
            <Binding Path="CurrentQuestion" Converter="{x:Static ObjectConverters.IsNotNull}" />
          </StackPanel.IsVisible>
          <TextBox x:Name="SaAnswerBox" Text="{Binding ShortAnswer}"
                   Watermark="Type your answer..."
                   FontSize="16" Padding="12,10" CornerRadius="8"
                   KeyDown="OnSaAnswerKeyDown"
                   IsVisible="{Binding !IsMcQuestion}" />
          <Button x:Name="SaSubmitBtn" Click="OnSaSubmitClick"
                  HorizontalAlignment="Center"
                  Padding="24,10" CornerRadius="8"
                  Classes="primary"
                  IsVisible="{Binding !IsMcQuestion}">
            <TextBlock Text="Submit Answer" FontSize="14" FontWeight="SemiBold" />
          </Button>
        </StackPanel>

        <!-- Reveal Solution Button (Commit 48) -->
        <Button Command="{Binding ShowSolutionCommand}"
                HorizontalAlignment="Center"
                Padding="20,10" CornerRadius="8"
                Classes="secondary"
                IsVisible="{Binding !IsSolutionVisible}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       VerticalAlignment="Center" />
            <TextBlock Text="Reveal Solution" FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Solution Panel (Commit 49) -->
        <Border IsVisible="{Binding IsSolutionVisible}"
                Background="{DynamicResource CorrectBackgroundBrush}"
                BorderBrush="{DynamicResource CorrectBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="24">
          <StackPanel Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                         Foreground="{DynamicResource CorrectTextBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Text="Solution" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource CorrectTextBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>
            <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="8"
                    Padding="16" BorderBrush="{DynamicResource CorrectBorderBrush}" BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock Text="Answer" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" />
                <Panel>
                  <ctrl:LaTeXImage LaTeXSource="{Binding CurrentQuestion.Answer}"
                                   IsVisible="{Binding SolutionHasLaTeX}"
                                   HorizontalAlignment="Left" />
                  <TextBlock Text="{Binding CurrentQuestion.Answer}" FontSize="16" FontWeight="Bold"
                             Foreground="{DynamicResource CorrectTextBrush}"
                             IsVisible="{Binding !SolutionHasLaTeX}" />
                </Panel>
              </StackPanel>
            </Border>
            <Panel IsVisible="{Binding SolutionHasLaTeX}">
              <ctrl:LaTeXImage LaTeXSource="{Binding CurrentQuestion.SolutionLaTeX}"
                               HorizontalAlignment="Left" />
            </Panel>
            <TextBlock Text="{Binding CurrentQuestion.SolutionText}" FontSize="13"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap" LineHeight="20"
                       IsVisible="{Binding !SolutionHasLaTeX}" />
          </StackPanel>
        </Border>

        <!-- Navigation Buttons (Commit 50) -->
        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
          <Button Command="{Binding NextQuestionCommand}"
                  Padding="24,10" CornerRadius="8"
                  Classes="primary">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Next Question" FontSize="14" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
              <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding EndSessionCommand}"
                  Padding="24,10" CornerRadius="8"
                  Classes="secondary">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         VerticalAlignment="Center" />
              <TextBlock Text="End Session" FontSize="14"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- Clipboard Copy Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Button Command="{Binding CopyQuestionCommand}"
                  Padding="12,6" CornerRadius="6"
                  Classes="secondary"
                  ToolTip.Tip="Copy question text">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                         VerticalAlignment="Center" />
              <TextBlock Text="Question" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding CopyAnswerCommand}"
                  Padding="12,6" CornerRadius="6"
                  Classes="secondary"
                  ToolTip.Tip="Copy answer">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                         VerticalAlignment="Center" />
              <TextBlock Text="Answer" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button Command="{Binding CopyFullCommand}"
                  Padding="12,6" CornerRadius="6"
                  Classes="secondary"
                  ToolTip.Tip="Copy question, answer, and solution">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                         VerticalAlignment="Center" />
              <TextBlock Text="Full" FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

        <!-- View Summary Button (shown after session ends) -->
        <StackPanel IsVisible="{Binding IsSessionOver}" Spacing="16" HorizontalAlignment="Center">
          <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                  Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  HorizontalAlignment="Center">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
              <TextBlock Text="Session Complete!" FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         HorizontalAlignment="Center" />
              <TextBlock Text="You've ended this practice session."
                         FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
          <Button Command="{Binding ViewSummaryCommand}"
                  HorizontalAlignment="Center"
                  Padding="24,12" CornerRadius="8"
                  Classes="primary">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                         VerticalAlignment="Center" />
              <TextBlock Text="View Summary" FontSize="14" FontWeight="SemiBold"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>

      </StackPanel>

      <!-- End Session Confirmation Dialog (Commit 52) -->
      <Border IsVisible="{Binding IsEndConfirmationVisible}"
              Background="{DynamicResource OverlayScrimBrush}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ZIndex="100">
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="360" MaxWidth="440">
          <StackPanel Spacing="20">
            <TextBlock Text="End Session?" FontSize="20" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}Are you sure? You've answered {0} of {1} questions.">
                  <Binding Path="AnsweredCount" />
                  <Binding Path="Questions.Count" />
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
              <Button Command="{Binding CancelEndSessionCommand}"
                      Padding="16,10" CornerRadius="8"
                      Classes="secondary">
                <TextBlock Text="No, Continue" FontSize="13" />
              </Button>
              <Button Command="{Binding ConfirmEndSessionCommand}"
                      Padding="16,10" CornerRadius="8"
                      Classes="danger">
                <TextBlock Text="Yes, End" FontSize="13" FontWeight="SemiBold" />
              </Button>
            </StackPanel>
          </StackPanel>
        </Border>
      </Border>

    </Grid>
  </ScrollViewer>
</UserControl>
