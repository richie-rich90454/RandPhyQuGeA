<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AvaloniaUI.Views.HelpWindow"
        Title="Physics Question Generator - Help"
        Width="600" Height="500"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer Padding="15">
        <StackPanel Spacing="12">
            <TextBlock Text="Physics Question Generator" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="User Manual" FontSize="18" FontWeight="SemiBold"/>

            <TextBlock Text="Getting Started" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">1. Place your specification file (part_one.txt) in the specifications/ directory.&#x0a;2. Launch the application.&#x0a;3. Use the filters on the left to narrow down question types.&#x0a;4. Click Generate or press Ctrl+N to create a question.&#x0a;5. Click 'Toggle Solution' to reveal the answer and solution steps.</TextBlock>

            <TextBlock Text="Keyboard Shortcuts" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">Ctrl+N - Generate a new question&#x0a;Ctrl+E - Open export dialog&#x0a;F1 - Open this help window</TextBlock>

            <TextBlock Text="Filters" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">Topic - Filter questions by topic area.&#x0a;Skill - Filter by specific skill.&#x0a;Difficulty - Set difficulty level (1-10).&#x0a;Type - Choose Short Answer (SA) or Multiple Choice (MC).</TextBlock>

            <TextBlock Text="Export Formats" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">Text - Plain text format.&#x0a;PDF - Formatted PDF document.&#x0a;HTML - Self-contained HTML with MathJax.&#x0a;Markdown - Markdown with LaTeX math.</TextBlock>

            <TextBlock Text="Specification File Format" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock TextWrapping="Wrap">The specification file uses section markers:&#x0a;[UNIT id:name] - Define a unit&#x0a;[TOPIC id:name unit:unitId] - Define a topic&#x0a;[SKILL id:name topic:topicId] - Define a skill&#x0a;[TEMPLATE ...] - Define a question template</TextBlock>

            <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>
