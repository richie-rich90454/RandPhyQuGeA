<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:cvt="using:AvaloniaUI.Converters"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="AvaloniaUI.Views.QuestionBankView"
             x:DataType="vm:QuestionBankViewModel">

  <UserControl.Resources>
    <cvt:DifficultyToBrushConverter x:Key="DifficultyToBrushConverter" />
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="ToggleButton">
      <Setter Property="Opacity" Value="0.5" />
    </Style>
    <Style Selector="ToggleButton:checked">
      <Setter Property="Opacity" Value="1.0" />
    </Style>
  </UserControl.Styles>

  <UserControl.DataTemplates>
    <!-- Unit → Topics hierarchy with colored header -->
    <TreeDataTemplate x:DataType="vm:UnitNode" ItemsSource="{Binding Topics}">
      <Border Background="{DynamicResource PrimarySubtleBrush}"
              CornerRadius="4" Padding="8,6" Margin="0,2">
        <DockPanel>
          <TextBlock DockPanel.Dock="Right"
                     Text="{Binding TemplateCount, StringFormat='{}{0} templates'}"
                     FontSize="11"
                     Foreground="{DynamicResource TextTertiaryBrush}"
                     VerticalAlignment="Center" Margin="8,0,0,0" />
          <TextBlock Text="{Binding Name}"
                     FontWeight="SemiBold" FontSize="14"
                     Foreground="{DynamicResource PrimaryBrush}" />
        </DockPanel>
      </Border>
    </TreeDataTemplate>

    <!-- Topic → Skills hierarchy with description tooltip -->
    <TreeDataTemplate x:DataType="vm:TopicNode" ItemsSource="{Binding Skills}">
      <Border Margin="8,2,0,2" Padding="6,4" CornerRadius="3"
              ToolTip.Tip="{Binding Description}">
        <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
      </Border>
    </TreeDataTemplate>

    <!-- Skill with template count badge and difficulty indicator -->
    <TreeDataTemplate x:DataType="vm:SkillNode">
      <DockPanel Margin="16,2,0,2">
        <!-- Template count badge -->
        <Border DockPanel.Dock="Right"
                Background="{Binding DifficultyLevel, Converter={StaticResource DifficultyToBrushConverter}}"
                CornerRadius="8" Padding="6,2" Margin="6,0,0,0"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding TemplateCount, StringFormat='{}{0}'}"
                     FontSize="10" FontWeight="SemiBold"
                     Foreground="{DynamicResource TextOnPrimaryBrush}" />
        </Border>
        <TextBlock Text="{Binding Name}" FontSize="12"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" />
      </DockPanel>
    </TreeDataTemplate>

    <!-- Template detail card in the detail panel -->
    <DataTemplate x:DataType="vm:TemplateNode">
      <Border Background="{DynamicResource CardBackgroundBrush}"
              CornerRadius="8" Padding="16" Margin="0,4"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel Spacing="8">
          <TextBlock Text="{Binding TextTemplate}" FontSize="13"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextPrimaryBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="{DynamicResource BadgeMCBrush}" CornerRadius="4" Padding="6,2">
              <TextBlock Text="{Binding QuestionType}" FontSize="10"
                         Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
            </Border>
            <Border Background="{DynamicResource BadgeMediumBrush}" CornerRadius="4" Padding="6,2">
              <TextBlock Text="{Binding Difficulty, StringFormat='Difficulty: {0}'}" FontSize="10"
                         Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
            </Border>
          </StackPanel>
          <TextBlock Text="{Binding AnswerExpression, StringFormat='Answer: {0}'}" FontSize="11"
                     Foreground="{DynamicResource TextTertiaryBrush}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid ColumnDefinitions="320,*">
    <!-- Empty State (no spec loaded) -->
    <Border Grid.ColumnSpan="2" Background="{DynamicResource ContentBackgroundBrush}"
            IsVisible="{Binding !HasData}">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="400">
        <!-- Icon -->
        <Border Background="{DynamicResource PrimarySubtleBrush}" CornerRadius="20"
                Width="80" Height="80" HorizontalAlignment="Center">
          <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="{DynamicResource PrimaryBrush}" />
        </Border>
        <TextBlock Text="No Specification Loaded" FontSize="22" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Load a specification file to browse the question bank. The tree view will display units, topics, and skills from your spec."
                   FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
        <Button Command="{Binding LoadSpecCommand}"
                HorizontalAlignment="Center"
                Padding="24,12" CornerRadius="8"
                Classes="primary">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                       Foreground="{DynamicResource TextOnPrimaryBrush}" VerticalAlignment="Center" />
            <TextBlock Text="Load Specification" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextOnPrimaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- Left Panel: TreeView Browser -->
    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0"
            IsVisible="{Binding HasData}">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Question Bank" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="16,16,16,4" />
        <!-- Search Box -->
        <Border DockPanel.Dock="Top" Margin="12,0,12,4" Padding="8,6"
                Background="{DynamicResource InputBackgroundBrush}"
                BorderBrush="{DynamicResource InputBorderBrush}" BorderThickness="1"
                CornerRadius="6">
          <TextBox Text="{Binding SearchText}"
                   Watermark="Search units, topics, skills..."
                   Background="Transparent" BorderThickness="0"
                   Padding="4,2" FontSize="13"
                   Foreground="{DynamicResource TextPrimaryBrush}" />
        </Border>
        <!-- Filter Chips -->
        <StackPanel DockPanel.Dock="Top" Margin="12,4,12,8" Spacing="4">
          <TextBlock Text="Difficulty" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="4,0,0,2" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <!-- Easy chip -->
            <ToggleButton IsChecked="{Binding FilterEasy}"
                          Content="Easy" FontSize="11" Padding="8,3" CornerRadius="10"
                          Background="{DynamicResource BadgeEasyBrush}"
                          Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
            <!-- Medium chip -->
            <ToggleButton IsChecked="{Binding FilterMedium}"
                          Content="Medium" FontSize="11" Padding="8,3" CornerRadius="10"
                          Background="{DynamicResource BadgeMediumBrush}"
                          Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
            <!-- Hard chip -->
            <ToggleButton IsChecked="{Binding FilterHard}"
                          Content="Hard" FontSize="11" Padding="8,3" CornerRadius="10"
                          Background="{DynamicResource BadgeHardBrush}"
                          Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
          </StackPanel>
          <TextBlock Text="Type" FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" Margin="4,4,0,2" />
          <StackPanel Orientation="Horizontal" Spacing="4">
            <!-- MC chip -->
            <ToggleButton IsChecked="{Binding FilterMC}"
                          Content="MC" FontSize="11" Padding="8,3" CornerRadius="10"
                          Background="{DynamicResource BadgeMCBrush}"
                          Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
            <!-- SA chip -->
            <ToggleButton IsChecked="{Binding FilterSA}"
                          Content="SA" FontSize="11" Padding="8,3" CornerRadius="10"
                          Background="{DynamicResource BadgeSABrush}"
                          Foreground="{DynamicResource TextOnPrimaryBrush}" FontWeight="SemiBold" />
          </StackPanel>
        </StackPanel>
        <TreeView ItemsSource="{Binding FilteredUnitNodes}"
                  SelectedItem="{Binding SelectedItem}"
                  x:Name="SpecTree" />
      </DockPanel>
    </Border>

    <!-- Right Panel: Detail Panel -->
    <Border Grid.Column="1" Background="{DynamicResource ContentBackgroundBrush}"
            IsVisible="{Binding HasData}">
      <Grid>
        <!-- No selection state -->
        <TextBlock Text="Select an item to view details" FontSize="14"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16"
                   IsVisible="{Binding !HasSelection}" />

        <!-- Detail content -->
        <ScrollViewer IsVisible="{Binding HasSelection}" Padding="24">
          <StackPanel Spacing="16">
            <!-- Header card -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="8" Padding="20"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding DetailTitle}" FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="{Binding DetailDescription}" FontSize="13"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </StackPanel>
            </Border>

            <!-- Stats row -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" Spacing="24">
                <StackPanel Spacing="2">
                  <TextBlock Text="Templates" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                  <TextBlock Text="{Binding DetailTemplateCount}" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Spacing="2">
                  <TextBlock Text="Difficulty" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                  <TextBlock Text="{Binding DetailDifficultyRange}" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
                <StackPanel Spacing="2">
                  <TextBlock Text="Types" FontSize="11"
                             Foreground="{DynamicResource TextTertiaryBrush}" />
                  <TextBlock Text="{Binding DetailQuestionTypes}" FontSize="14" FontWeight="SemiBold"
                             Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Templates list (visible when skill is selected) -->
            <StackPanel IsVisible="{Binding IsSkillSelected}" Spacing="4">
              <TextBlock Text="Templates" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,4" />
              <ItemsControl ItemsSource="{Binding DetailTemplates}" />
            </StackPanel>

            <!-- Start Practice Button -->
            <Button Command="{Binding StartPracticeCommand}"
                    IsVisible="{Binding HasSelection}"
                    HorizontalAlignment="Stretch"
                    Padding="16,12" CornerRadius="8"
                    Classes="primary"
                    HorizontalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{DynamicResource TextOnPrimaryBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PracticeContextText}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextOnPrimaryBrush}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>

</UserControl>
