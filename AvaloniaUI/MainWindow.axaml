<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="AvaloniaUI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Physics Question Generator"
        Width="900" Height="700">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding GenerateCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCommand}" />
  </Window.KeyBindings>

  <Grid ColumnDefinitions="250,*,200" RowDefinitions="Auto,*,Auto">
    <!-- Left Panel: Filters -->
    <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="10">
      <StackPanel Spacing="8">
        <TextBlock Text="Filters" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Text="Topic"/>
        <ComboBox ItemsSource="{Binding AvailableTopics}" SelectedItem="{Binding SelectedTopicId}" />
        <TextBlock Text="Skill"/>
        <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedSkillId}" />
        <TextBlock Text="Difficulty"/>
        <NumericUpDown Value="{Binding SelectedDifficulty}" Minimum="1" Maximum="10" />
        <TextBlock Text="Type"/>
        <ComboBox SelectedItem="{Binding SelectedQuestionType}">
          <sys:String>Any</sys:String>
          <sys:String>SA</sys:String>
          <sys:String>MC</sys:String>
        </ComboBox>
        <Button Content="Generate (Ctrl+N)" Command="{Binding GenerateCommand}" HorizontalAlignment="Stretch" Classes="accent" Margin="0,12,0,0"/>
        <Button Content="Clear Filters" Click="ClearFilters_Click" HorizontalAlignment="Stretch" Margin="0,4,0,0"/>
      </StackPanel>
    </Border>

    <!-- Center: Question Display -->
    <ScrollViewer Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Padding="15">
      <StackPanel Spacing="12">
        <TextBlock Text="{Binding QuestionText}" FontSize="16" TextWrapping="Wrap" />

        <!-- Choices for MC -->
        <ItemsControl ItemsSource="{Binding Choices}" IsVisible="{Binding HasChoices}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,2">
                <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Answer -->
        <Border Background="{DynamicResource SystemControlHighlightListLowBrush}" CornerRadius="4" Padding="10" IsVisible="{Binding IsSolutionVisible}">
          <StackPanel Spacing="6">
            <TextBlock Text="Answer" FontWeight="Bold" FontSize="14"/>
            <TextBlock Text="{Binding AnswerText}" FontSize="16" Foreground="Green"/>
            <TextBlock Text="Solution" FontWeight="Bold" FontSize="14" Margin="0,8,0,0"/>
            <TextBlock Text="{Binding SolutionText}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Button Content="Toggle Solution" Command="{Binding ToggleSolutionCommand}" HorizontalAlignment="Left"/>
      </StackPanel>
    </ScrollViewer>

    <!-- Right Panel: History -->
    <Border Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="10">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="History" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
        <Button DockPanel.Dock="Top" Content="Clear" Command="{Binding ClearHistoryCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
        <ListBox ItemsSource="{Binding History}" SelectedItem="{Binding CurrentQuestion}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis" MaxHeight="60" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Status Bar -->
    <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="8,4">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Content="Copy" Command="{Binding CopyToClipboardCommand}" Margin="4,0"/>
        <Button Grid.Column="2" Content="Export (Ctrl+E)" Command="{Binding ExportCommand}" Margin="4,0"/>
      </Grid>
    </Border>
  </Grid>
</Window>
