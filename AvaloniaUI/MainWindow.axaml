<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="AvaloniaUI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Physics Question Generator"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="550"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding GenerateCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCommand}" />
  </Window.KeyBindings>

  <SplitView IsPaneOpen="{Binding Navigation.IsPaneOpen}"
             DisplayMode="CompactInline"
             OpenPaneLength="280"
             CompactPaneLength="60"
             PanePlacement="Left">
    <SplitView.Pane>
      <Border Background="{DynamicResource NavPaneBackgroundBrush}">
        <DockPanel>
          <!-- App Title in Pane -->
          <Border DockPanel.Dock="Top" Padding="16,20" IsVisible="{Binding Navigation.IsPaneOpen}">
            <StackPanel Spacing="4">
              <TextBlock Text="Physics QG" FontSize="18" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Question Generator" FontSize="11"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>
          </Border>

          <!-- Navigation Items -->
          <ScrollViewer>
            <StackPanel Spacing="2" Margin="8,8">
              <!-- Home -->
              <Button Click="NavButton_Click" Tag="Home" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavHome"
                      ToolTip.Tip="Home (Ctrl+1)"
                      AutomationProperties.Name="Navigate to Home">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Home" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>

              <!-- Mental Practice -->
              <Button Click="NavButton_Click" Tag="MentalPractice" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavMentalPractice"
                      ToolTip.Tip="Mental Practice (Ctrl+2)"
                      AutomationProperties.Name="Navigate to Mental Practice">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Mental Practice" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>

              <!-- Focused Practice -->
              <Button Click="NavButton_Click" Tag="FocusedPractice" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavFocusedPractice"
                      ToolTip.Tip="Focused Practice (Ctrl+3)"
                      AutomationProperties.Name="Navigate to Focused Practice">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Focused Practice" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>

              <!-- Question Bank -->
              <Button Click="NavButton_Click" Tag="QuestionBank" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavQuestionBank"
                      ToolTip.Tip="Question Bank (Ctrl+4)"
                      AutomationProperties.Name="Navigate to Question Bank">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Question Bank" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>

              <!-- Progress -->
              <Button Click="NavButton_Click" Tag="Progress" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavProgress"
                      ToolTip.Tip="Progress (Ctrl+5)"
                      AutomationProperties.Name="Navigate to Progress">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Progress" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>

              <!-- Settings -->
              <Button Click="NavButton_Click" Tag="Settings" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left" Padding="0" CornerRadius="6"
                      Background="Transparent" x:Name="NavSettings"
                      ToolTip.Tip="Settings (Ctrl+6)"
                      AutomationProperties.Name="Navigate to Settings">
                <Grid ColumnDefinitions="48,*" MinHeight="44">
                  <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}" />
                  <TextBlock Grid.Column="1" Text="Settings" FontSize="13"
                             VerticalAlignment="Center"
                             Foreground="{DynamicResource NavItemInactiveTextBrush}"
                             IsVisible="{Binding Navigation.IsPaneOpen}" />
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </SplitView.Pane>

    <SplitView.Content>
      <Grid>
        <DockPanel>
          <!-- Header Bar with Hamburger Toggle -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PaneBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1"
                Padding="8,0" MinHeight="48">
          <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
            <!-- Hamburger Toggle Button -->
            <Button Grid.Column="0" Click="TogglePane_Click"
                    VerticalAlignment="Center" Padding="8"
                    CornerRadius="6" Background="Transparent"
                    ToolTip.Tip="Toggle navigation pane"
                    AutomationProperties.Name="Toggle navigation pane">
              <Grid Width="20" Height="16">
                <Rectangle x:Name="HamburgerTop" Fill="{DynamicResource TextPrimaryBrush}"
                           Height="2" RadiusX="1" RadiusY="1"
                           VerticalAlignment="Top" />
                <Rectangle x:Name="HamburgerMid" Fill="{DynamicResource TextPrimaryBrush}"
                           Height="2" RadiusX="1" RadiusY="1"
                           VerticalAlignment="Center" />
                <Rectangle x:Name="HamburgerBot" Fill="{DynamicResource TextPrimaryBrush}"
                           Height="2" RadiusX="1" RadiusY="1"
                           VerticalAlignment="Bottom" />
              </Grid>
            </Button>

            <!-- Breadcrumb Title Area -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                        VerticalAlignment="Center" Margin="12,0,0,0">
              <TextBlock Text="Physics QG" FontSize="13"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Text="/" FontSize="13"
                         Foreground="{DynamicResource TextTertiaryBrush}"
                         VerticalAlignment="Center" />
              <TextBlock Text="{Binding Navigation.CurrentViewTitle}" FontSize="14" FontWeight="SemiBold"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         VerticalAlignment="Center" />
            </StackPanel>

            <!-- Right Actions -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <Button Click="Help_Click" Padding="8" CornerRadius="6" Background="Transparent"
                      ToolTip.Tip="Help (F1)"
                      AutomationProperties.Name="Open help window">
                <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </Button>
              <Button Click="About_Click" Padding="8" CornerRadius="6" Background="Transparent"
                      ToolTip.Tip="About"
                      AutomationProperties.Name="About this application">
                <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Content Area -->
        <ContentControl x:Name="ContentArea" />
      </DockPanel>

      <!-- Keyboard Shortcut Help Overlay -->
      <Border x:Name="ShortcutOverlay" IsVisible="False"
              Background="{DynamicResource OverlayScrimBrush}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ZIndex="200" Cursor="Hand"
              PointerPressed="OnShortcutOverlayDismiss">
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12"
                Padding="32" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="400" MaxWidth="520"
                Cursor="Arrow">
          <StackPanel Spacing="20">
            <StackPanel Spacing="4">
              <TextBlock Text="Keyboard Shortcuts" FontSize="20" FontWeight="Bold"
                         Foreground="{DynamicResource TextPrimaryBrush}" />
              <TextBlock Text="Press ? or Ctrl+/ to toggle this overlay" FontSize="12"
                         Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <!-- Navigation -->
              <TextBlock Text="Navigation" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource PrimaryBrush}" />
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+1" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Home" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+2" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Mental Practice" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+3" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Focused Practice" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+4" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Question Bank" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+5" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Progress" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+6" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Settings" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
            </StackPanel>

            <StackPanel Spacing="8">
              <!-- Actions -->
              <TextBlock Text="Actions" FontSize="13" FontWeight="SemiBold"
                         Foreground="{DynamicResource PrimaryBrush}" />
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+N" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Generate new question" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Ctrl+E" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Export questions" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="F1" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Open help window" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="Esc" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Go back to Home" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
              <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                <Border Background="{DynamicResource Neutral10Brush}" CornerRadius="4" Padding="8,4" MinWidth="80">
                  <TextBlock Text="? / Ctrl+/" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Grid.Column="1" Text="Show this shortcut overlay" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
              </Grid>
            </StackPanel>

            <TextBlock Text="Click anywhere to dismiss" FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Border>

      <!-- Konami Code Easter Egg Overlay -->
      <Border x:Name="KonamiOverlay" IsVisible="False"
              Background="{DynamicResource OverlayScrimBrush}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ZIndex="300" Cursor="Hand"
              PointerPressed="KonamiOverlayDismiss">
        <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="16"
                Padding="48" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Cursor="Arrow">
          <StackPanel Spacing="16" HorizontalAlignment="Center">
            <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                       Foreground="{DynamicResource WarningBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="You found the secret!" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="The laws of physics are but one set of rules." FontSize="16" FontStyle="Italic"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="You've proven that some rules are meant to be discovered." FontSize="14"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Click anywhere to close" FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0" />
          </StackPanel>
        </Border>
      </Border>

      </Grid>
    </SplitView.Content>
  </SplitView>
</Window>
