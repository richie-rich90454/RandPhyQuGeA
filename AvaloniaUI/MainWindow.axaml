<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="AvaloniaUI.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Physics Question Generator"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="550"
        Background="#F8F8F8"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding GenerateCommand}" />
    <KeyBinding Gesture="Ctrl+E" Command="{Binding ExportCommand}" />
  </Window.KeyBindings>

  <DockPanel>
    <!-- Menu Bar -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Generate Question" InputGesture="Ctrl+N" Command="{Binding GenerateCommand}" />
        <Separator />
        <MenuItem Header="_Export..." InputGesture="Ctrl+E" Command="{Binding ExportCommand}" />
        <Separator />
        <MenuItem Header="E_xit" Click="Exit_Click" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="_Copy Question" Command="{Binding CopyToClipboardCommand}" />
        <MenuItem Header="Clear _History" Command="{Binding ClearHistoryCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_Help" InputGesture="F1" Click="Help_Click" />
        <MenuItem Header="_About" Click="About_Click" />
      </MenuItem>
    </Menu>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontSize="12" Foreground="#616161" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{Binding History.Count, StringFormat='{}{0} questions'}" FontSize="12" Foreground="#808080" VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <Grid ColumnDefinitions="280,*,240" Margin="0">

      <!-- Left Panel: Filters -->
      <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <DockPanel>
          <!-- Panel Header -->
          <Border DockPanel.Dock="Top" Padding="20,16" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <TextBlock Text="Filters" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A" />
          </Border>

          <!-- Generate Button (pinned to bottom) -->
          <Border DockPanel.Dock="Bottom" Padding="16" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <StackPanel Spacing="8">
              <Button Command="{Binding GenerateCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      Height="40" CornerRadius="6" Background="#0078D4" Foreground="#FFFFFF"
                      Classes="accent">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                  <TextBlock Text="Generate" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
              <Button Click="ClearFilters_Click" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                      Height="32" CornerRadius="6">
                <TextBlock Text="Clear Filters" FontSize="12" Foreground="#616161" />
              </Button>
            </StackPanel>
          </Border>

          <!-- Filter Controls -->
          <ScrollViewer>
            <StackPanel Spacing="16" Margin="20,16">
              <!-- Topic -->
              <StackPanel Spacing="6">
                <TextBlock Text="Topic" FontSize="12" FontWeight="SemiBold" Foreground="#616161" />
                <ComboBox ItemsSource="{Binding AvailableTopics}" SelectedItem="{Binding SelectedTopicId}"
                          HorizontalAlignment="Stretch" PlaceholderText="All Topics" />
              </StackPanel>

              <!-- Skill -->
              <StackPanel Spacing="6">
                <TextBlock Text="Skill" FontSize="12" FontWeight="SemiBold" Foreground="#616161" />
                <ComboBox ItemsSource="{Binding AvailableSkills}" SelectedItem="{Binding SelectedSkillId}"
                          HorizontalAlignment="Stretch" PlaceholderText="All Skills" />
              </StackPanel>

              <!-- Difficulty -->
              <StackPanel Spacing="6">
                <TextBlock Text="Difficulty" FontSize="12" FontWeight="SemiBold" Foreground="#616161" />
                <NumericUpDown Value="{Binding SelectedDifficulty}" Minimum="1" Maximum="10"
                               HorizontalAlignment="Stretch" />
              </StackPanel>

              <!-- Question Type -->
              <StackPanel Spacing="6">
                <TextBlock Text="Question Type" FontSize="12" FontWeight="SemiBold" Foreground="#616161" />
                <ComboBox SelectedItem="{Binding SelectedQuestionType}" HorizontalAlignment="Stretch"
                          PlaceholderText="Any Type">
                  <sys:String>Any</sys:String>
                  <sys:String>SA</sys:String>
                  <sys:String>MC</sys:String>
                </ComboBox>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- Center: Question Display -->
      <ScrollViewer Grid.Column="1" Padding="24">
        <StackPanel Spacing="16">
          <!-- Empty State / Question Card -->
          <Border IsVisible="{Binding !HasQuestion}" Background="#FFFFFF" CornerRadius="8"
                  BorderBrush="#E0E0E0" BorderThickness="1" Padding="40" MinHeight="300">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
              <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                         HorizontalAlignment="Center" Foreground="#B0B0B0" />
              <TextBlock Text="No question generated yet" FontSize="18" Foreground="#808080"
                         HorizontalAlignment="Center" />
              <TextBlock Text="Click Generate or press Ctrl+N to create a question" FontSize="13"
                         Foreground="#B0B0B0" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Question Content (visible when question exists) -->
          <Border IsVisible="{Binding HasQuestion}" Background="#FFFFFF" CornerRadius="8"
                  BorderBrush="#E0E0E0" BorderThickness="1" Padding="24">
            <StackPanel Spacing="16">
              <!-- Question Header -->
              <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Background="#0078D4" CornerRadius="4" Padding="8,4">
                  <TextBlock Text="{Binding CurrentQuestion.QuestionType}" FontSize="11"
                             FontWeight="SemiBold" Foreground="#FFFFFF" />
                </Border>
                <Border Background="#F0F0F0" CornerRadius="4" Padding="8,4">
                  <TextBlock Text="{Binding CurrentQuestion.Difficulty, StringFormat='Difficulty: {0}'}"
                             FontSize="11" Foreground="#616161" />
                </Border>
              </StackPanel>

              <!-- Question Text -->
              <TextBlock Text="{Binding QuestionText}" FontSize="16" TextWrapping="Wrap"
                         LineHeight="24" Foreground="#1A1A1A" />

              <!-- Choices for MC -->
              <ItemsControl ItemsSource="{Binding Choices}" IsVisible="{Binding HasChoices}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Background="#F8F8F8" CornerRadius="6" Padding="14,10" BorderBrush="#E0E0E0"
                            BorderThickness="1" Margin="0,0,0,8">
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse Width="8" Height="8" Fill="#0078D4" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="14" Foreground="#1A1A1A" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Toggle Solution Button -->
              <Button Command="{Binding ToggleSolutionCommand}" HorizontalAlignment="Left"
                      Padding="16,8" CornerRadius="6" Background="#F0F0F0">
                <TextBlock Text="{Binding ToggleSolutionText}" FontSize="12" />
              </Button>

              <!-- Solution Panel -->
              <Border IsVisible="{Binding IsSolutionVisible}" Background="#F0FAF0" CornerRadius="8"
                      BorderBrush="#C8E6C8" BorderThickness="1" Padding="20">
                <StackPanel Spacing="12">
                  <TextBlock Text="Answer" FontWeight="SemiBold" FontSize="14" Foreground="#107C10" />
                  <TextBlock Text="{Binding AnswerText}" FontSize="18" FontWeight="Bold"
                             Foreground="#107C10" />
                  <Border Height="1" Background="#C8E6C8" Margin="0,4" />
                  <TextBlock Text="Solution" FontWeight="SemiBold" FontSize="14" Foreground="#1A1A1A" />
                  <TextBlock Text="{Binding SolutionText}" TextWrapping="Wrap" FontSize="14"
                             LineHeight="22" Foreground="#1A1A1A" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <!-- Action Buttons -->
          <StackPanel IsVisible="{Binding HasQuestion}" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
            <Button Command="{Binding CopyToClipboardCommand}" Padding="12,6" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="Copy" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Command="{Binding ExportCommand}" Padding="12,6" CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="Export" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- Right Panel: History -->
      <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
        <DockPanel>
          <!-- Panel Header -->
          <Border DockPanel.Dock="Top" Padding="16" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="History" FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A" VerticalAlignment="Center" />
              <Button Grid.Column="1" Command="{Binding ClearHistoryCommand}" Padding="8,4" CornerRadius="4"
                      FontSize="11" Foreground="#616161">
                Clear
              </Button>
            </Grid>
          </Border>

          <!-- History List -->
          <ListBox ItemsSource="{Binding History}" SelectedItem="{Binding CurrentQuestion}"
                   Background="Transparent" BorderThickness="0" Padding="4">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8,8" CornerRadius="6" Margin="0,2">
                  <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <Border Background="#0078D4" CornerRadius="3" Padding="4,2">
                        <TextBlock Text="{Binding QuestionType}" FontSize="10" Foreground="#FFFFFF" />
                      </Border>
                      <TextBlock Text="{Binding Difficulty, StringFormat='L{0}'}" FontSize="10"
                                 Foreground="#808080" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis" MaxHeight="48"
                               FontSize="12" Foreground="#1A1A1A" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
