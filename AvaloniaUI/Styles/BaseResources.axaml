<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         COLOR PALETTE
         A cohesive, accessible palette inspired by College Board's
         professional assessment platform aesthetic.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Primary Accent -->
    <Color x:Key="PrimaryColor">#0053B6</Color>
    <Color x:Key="PrimaryLightColor">#3B7DDD</Color>
    <Color x:Key="PrimaryDarkColor">#003D87</Color>
    <Color x:Key="PrimarySubtleColor">#E8F0FE</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#0E7C3B</Color>
    <Color x:Key="SuccessLightColor">#E6F4EA</Color>
    <Color x:Key="WarningColor">#D47600</Color>
    <Color x:Key="WarningLightColor">#FFF3E0</Color>
    <Color x:Key="ErrorColor">#C5221F</Color>
    <Color x:Key="ErrorLightColor">#FCE8E6</Color>
    <Color x:Key="InfoColor">#1A73E8</Color>
    <Color x:Key="InfoLightColor">#E8F0FE</Color>

    <!-- Neutral Colors -->
    <Color x:Key="Neutral00">#FFFFFF</Color>
    <Color x:Key="Neutral05">#F8F9FA</Color>
    <Color x:Key="Neutral10">#F1F3F4</Color>
    <Color x:Key="Neutral20">#E8EAED</Color>
    <Color x:Key="Neutral30">#DADCE0</Color>
    <Color x:Key="Neutral40">#BDC1C6</Color>
    <Color x:Key="Neutral50">#9AA0A6</Color>
    <Color x:Key="Neutral60">#80868B</Color>
    <Color x:Key="Neutral70">#5F6368</Color>
    <Color x:Key="Neutral80">#3C4043</Color>
    <Color x:Key="Neutral90">#202124</Color>

    <!-- Surface Colors -->
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceVariantColor">#F8F9FA</Color>
    <Color x:Key="BackgroundColor">#F1F3F4</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>

    <!-- ═══════════════════════════════════════════════════════════════
         BRUSH RESOURCES
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Primary Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource PrimarySubtleColor}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ErrorLightBrush" Color="{StaticResource ErrorLightColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}" />

    <!-- Neutral Brushes -->
    <SolidColorBrush x:Key="Neutral00Brush" Color="{StaticResource Neutral00}" />
    <SolidColorBrush x:Key="Neutral05Brush" Color="{StaticResource Neutral05}" />
    <SolidColorBrush x:Key="Neutral10Brush" Color="{StaticResource Neutral10}" />
    <SolidColorBrush x:Key="Neutral20Brush" Color="{StaticResource Neutral20}" />
    <SolidColorBrush x:Key="Neutral30Brush" Color="{StaticResource Neutral30}" />
    <SolidColorBrush x:Key="Neutral40Brush" Color="{StaticResource Neutral40}" />
    <SolidColorBrush x:Key="Neutral50Brush" Color="{StaticResource Neutral50}" />
    <SolidColorBrush x:Key="Neutral60Brush" Color="{StaticResource Neutral60}" />
    <SolidColorBrush x:Key="Neutral70Brush" Color="{StaticResource Neutral70}" />
    <SolidColorBrush x:Key="Neutral80Brush" Color="{StaticResource Neutral80}" />
    <SolidColorBrush x:Key="Neutral90Brush" Color="{StaticResource Neutral90}" />

    <!-- Surface Brushes -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}" />
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />

    <!-- ═══════════════════════════════════════════════════════════════
         SPACING
         Consistent 4px base grid for predictable layout rhythm.
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="SpacingXXS">2</x:Double>
    <x:Double x:Key="SpacingXS">4</x:Double>
    <x:Double x:Key="SpacingSM">8</x:Double>
    <x:Double x:Key="SpacingMD">12</x:Double>
    <x:Double x:Key="SpacingLG">16</x:Double>
    <x:Double x:Key="SpacingXL">24</x:Double>
    <x:Double x:Key="SpacingXXL">32</x:Double>
    <x:Double x:Key="SpacingXXXL">48</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         CORNER RADII
         ═══════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="CornerRadiusNone">0</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXS">2</CornerRadius>
    <CornerRadius x:Key="CornerRadiusSM">4</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMD">8</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLG">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXL">16</CornerRadius>
    <CornerRadius x:Key="CornerRadiusFull">9999</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="FontSizeXS">10</x:Double>
    <x:Double x:Key="FontSizeSM">11</x:Double>
    <x:Double x:Key="FontSizeBase">13</x:Double>
    <x:Double x:Key="FontSizeMD">14</x:Double>
    <x:Double x:Key="FontSizeLG">16</x:Double>
    <x:Double x:Key="FontSizeXL">20</x:Double>
    <x:Double x:Key="FontSizeXXL">24</x:Double>
    <x:Double x:Key="FontSizeXXXL">32</x:Double>
    <x:Double x:Key="FontSizeDisplay">40</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         SIZING
         ═══════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="IconSizeSM">12</x:Double>
    <x:Double x:Key="IconSizeMD">16</x:Double>
    <x:Double x:Key="IconSizeLG">20</x:Double>
    <x:Double x:Key="IconSizeXL">24</x:Double>
    <x:Double x:Key="IconSizeXXL">32</x:Double>

    <x:Double x:Key="ButtonHeightSM">28</x:Double>
    <x:Double x:Key="ButtonHeightMD">36</x:Double>
    <x:Double x:Key="ButtonHeightLG">44</x:Double>

    <x:Double x:Key="NavPaneWidth">280</x:Double>
    <x:Double x:Key="NavPaneCompactWidth">60</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         ELEVATION (Box Shadows)
         ═══════════════════════════════════════════════════════════════ -->
    <x:String x:Key="ShadowSM">0 1 2 0 rgba(0,0,0,0.1)</x:String>
    <x:String x:Key="ShadowMD">0 2 4 0 rgba(0,0,0,0.1)</x:String>
    <x:String x:Key="ShadowLG">0 4 8 0 rgba(0,0,0,0.12)</x:String>
    <x:String x:Key="ShadowXL">0 8 16 0 rgba(0,0,0,0.14)</x:String>

</ResourceDictionary>
