<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         LIGHT THEME OVERRIDES
         Overrides for light mode — bright surfaces, dark text.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202124" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5F6368" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#9AA0A6" />
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#BDC1C6" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F1F3F4" />
    <SolidColorBrush x:Key="PaneBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#F8F9FA" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="#F8F9FA" />
    <SolidColorBrush x:Key="OverlayBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OverlayScrimBrush" Color="#C0000000" />
    <SolidColorBrush x:Key="HeaderBarBackgroundBrush" Color="#F1F3F4" />

    <!-- Borders & Dividers -->
    <SolidColorBrush x:Key="BorderBrush" Color="#DADCE0" />
    <SolidColorBrush x:Key="DividerBrush" Color="#E8EAED" />
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#0053B6" />

    <!-- Navigation -->
    <SolidColorBrush x:Key="NavPaneBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="NavItemSelectedBrush" Color="#E8F0FE" />
    <SolidColorBrush x:Key="NavItemHoverBrush" Color="#F1F3F4" />
    <SolidColorBrush x:Key="NavItemActiveTextBrush" Color="#0053B6" />
    <SolidColorBrush x:Key="NavItemInactiveTextBrush" Color="#5F6368" />

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#DADCE0" />
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#0053B6" />
    <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#9AA0A6" />

    <!-- Status Bar -->
    <SolidColorBrush x:Key="StatusBarBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="StatusBarTextBrush" Color="#5F6368" />

    <!-- Menu -->
    <SolidColorBrush x:Key="MenuBarBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#F1F3F4" />

    <!-- Badge Colors -->
    <SolidColorBrush x:Key="BadgeMCBrush" Color="#0053B6" />
    <SolidColorBrush x:Key="BadgeSABrush" Color="#7B1FA2" />
    <SolidColorBrush x:Key="BadgeEasyBrush" Color="#0E7C3B" />
    <SolidColorBrush x:Key="BadgeMediumBrush" Color="#D47600" />
    <SolidColorBrush x:Key="BadgeHardBrush" Color="#C5221F" />

    <!-- Timer Colors -->
    <SolidColorBrush x:Key="TimerNormalBrush" Color="#0053B6" />
    <SolidColorBrush x:Key="TimerWarningBrush" Color="#D47600" />
    <SolidColorBrush x:Key="TimerCriticalBrush" Color="#C5221F" />

    <!-- Answer Feedback -->
    <SolidColorBrush x:Key="CorrectBackgroundBrush" Color="#E6F4EA" />
    <SolidColorBrush x:Key="CorrectBorderBrush" Color="#A8DAB5" />
    <SolidColorBrush x:Key="CorrectTextBrush" Color="#0E7C3B" />
    <SolidColorBrush x:Key="IncorrectBackgroundBrush" Color="#FCE8E6" />
    <SolidColorBrush x:Key="IncorrectBorderBrush" Color="#F5C6CB" />
    <SolidColorBrush x:Key="IncorrectTextBrush" Color="#C5221F" />

    <!-- Progress -->
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#E8EAED" />
    <SolidColorBrush x:Key="ProgressBarFillBrush" Color="#0053B6" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#BDC1C6" />
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="Transparent" />

    <!-- Theme Preview Brushes -->
    <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#1A1A2E" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#F57C00" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9AA0A6" />

</ResourceDictionary>
