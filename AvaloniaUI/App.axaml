<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AvaloniaUI.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <!-- Spacing -->
        <x:Double x:Key="SpacingSmall">4</x:Double>
        <x:Double x:Key="SpacingMedium">8</x:Double>
        <x:Double x:Key="SpacingLarge">16</x:Double>
        <x:Double x:Key="SpacingXLarge">24</x:Double>

        <!-- Corner radii -->
        <CornerRadius x:Key="CornerRadiusSmall">4</CornerRadius>
        <CornerRadius x:Key="CornerRadiusMedium">8</CornerRadius>

        <!-- Custom colors -->
        <Color x:Key="AppAccentColor">#0078D4</Color>
        <Color x:Key="AppAccentColorLight">#4DA6E8</Color>
        <Color x:Key="AppSuccessColor">#107C10</Color>
        <Color x:Key="AppWarningColor">#FF8C00</Color>
        <Color x:Key="AppErrorColor">#D13438</Color>
        <Color x:Key="AppSurfaceColor">#F8F8F8</Color>
        <Color x:Key="AppCardColor">#FFFFFF</Color>
        <Color x:Key="AppBorderColor">#E0E0E0</Color>
    </Application.Resources>
</Application>
