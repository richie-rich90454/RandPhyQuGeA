<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaUI.ViewModels"
             xmlns:v="using:AvaloniaUI.Views"
             x:Class="AvaloniaUI.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <FluentTheme />

        <!-- Nav button classes: subtle hover, no FluentTheme chrome -->
        <Style Selector="Button.nav-item">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavItemHoverBrush}" />
        </Style>
        <Style Selector="Button.nav-item:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavItemSelectedBrush}" />
        </Style>
        <Style Selector="Button.nav-item.selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavItemSelectedBrush}" />
        </Style>
        <Style Selector="Button.nav-item.selected TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource NavItemActiveTextBrush}" />
        </Style>

        <!-- Icon/subtle button class: minimal hover feedback -->
        <Style Selector="Button.subtle">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.subtle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavItemHoverBrush}" />
        </Style>
        <Style Selector="Button.subtle:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        </Style>

        <!-- Primary action button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}" />
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource PrimaryDarkBrush}" />
        </Style>
        <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Neutral30Brush}" />
        </Style>

        <!-- Secondary/neutral button -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="{DynamicResource Neutral10Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Neutral20Brush}" />
        </Style>
        <Style Selector="Button.secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Neutral30Brush}" />
        </Style>

        <!-- Danger/destructive button -->
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/BaseResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.DataTemplates>
        <DataTemplate x:DataType="vm:HomeViewModel">
            <v:HomeView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:MentalPracticeViewModel">
            <v:MentalPracticeView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:FocusedPracticeViewModel">
            <v:FocusedPracticeView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:QuestionBankViewModel">
            <v:QuestionBankView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:ProgressViewModel">
            <v:ProgressView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:SettingsViewModel">
            <v:SettingsView />
        </DataTemplate>
        <DataTemplate x:DataType="vm:SessionSummaryViewModel">
            <v:SessionSummaryView />
        </DataTemplate>
    </Application.DataTemplates>
</Application>
